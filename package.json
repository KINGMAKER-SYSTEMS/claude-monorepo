{
  "name": "claude-superbrain",
  "version": "0.0.1",
  "private": true,
  "description": "Postgres-backed superbrain indexing all projects and infrastructure for Claude Code / Claude Desktop routines.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:migrate": "pnpm --filter @brain/db migrate",
    "db:generate": "pnpm --filter @brain/db generate",
    "brain": "pnpm --filter @brain/cli start",
    "standup": "pnpm --filter @brain/cli start standup"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
